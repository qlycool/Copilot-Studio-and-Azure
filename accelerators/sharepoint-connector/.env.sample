# ============================================================
# SharePoint → Azure AI Search Connector
# Copy this file to .env and fill in your values
#
# AUTHENTICATION:
#   By default, the connector uses DefaultAzureCredential
#   (managed identity / Azure CLI / env vars).
#   Client secrets are optional fallback for SharePoint/Graph only.
#   Search and Foundry always use managed identity (no API key option).
#
# REQUIRED RBAC ROLES (when using managed identity):
#   - Azure AI Search:   "Search Index Data Contributor" + "Search Service Contributor"
#   - Azure OpenAI:      "Cognitive Services OpenAI User"
#   - Graph API:         App registration with Sites.Read.All + Files.Read.All
#                        application permissions (admin-consented)
# ============================================================

# --- Microsoft Entra ID (for Graph API access to SharePoint) ---
TENANT_ID=your-tenant-id
# CLIENT_ID and CLIENT_SECRET are only needed if NOT using managed identity.
# When using managed identity, leave these empty or remove them.
CLIENT_ID=
CLIENT_SECRET=

# --- SharePoint Site ---
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/YourSite
# Optional: comma-separated list of specific library names to index
# Leave empty to index the default document library
SHAREPOINT_LIBRARIES=

# --- Azure AI Search ---
# Authenticates via DefaultAzureCredential (managed identity / Azure CLI).
# Requires "Search Index Data Contributor" + "Search Service Contributor" roles.
SEARCH_ENDPOINT=https://your-search-service.search.windows.net
SEARCH_INDEX_NAME=sharepoint-index

# --- Foundry (for embeddings) ---
# Authenticates via DefaultAzureCredential (managed identity / Azure CLI).
# Requires "Cognitive Services OpenAI User" role on the resource.
FOUNDRY_ENDPOINT=https://your-openai-resource.openai.azure.com
FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-large
FOUNDRY_EMBEDDING_DIMENSIONS=1536

# --- Indexer Settings ---
# Comma-separated file extensions to index (matches preview connector formats)
INDEXED_EXTENSIONS=.pdf,.docx,.docm,.xlsx,.xlsm,.pptx,.pptm,.txt,.md,.csv,.json,.xml,.kml,.html,.htm,.rtf,.eml,.epub,.msg,.odt,.ods,.odp,.zip,.gz
# Chunk size in characters
CHUNK_SIZE=2000
# Chunk overlap in characters
CHUNK_OVERLAP=200
# Max concurrent document processing
MAX_CONCURRENCY=4
# Max file size in MB (files larger than this are skipped)
MAX_FILE_SIZE_MB=100
# How far back to look for changes (minutes). 0 = full reindex
INCREMENTAL_MINUTES=0
